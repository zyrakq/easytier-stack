# Generated by stackbuilder from concatenated .env.example files
# Source files: base/.env.example, ipv4/.env.example, private-mode/.env.example, peer/.env.example, stun/.env.example, point-to-network/.env.example

# === BASE CONFIGURATION ===
# Project name for Docker Compose
COMPOSE_PROJECT_NAME=easytier

# Docker image
IMAGE=easytier/easytier:latest

# Logging
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
LOG_COMPRESS=true

ET_NETWORK_NAME=easytier
ET_NETWORK_SECRET=XkQ6DuvzYtEe1TjCCKOFC697rCIhpyEx
# IPv4
ET_IPV4=10.144.144.1
# Private mode
ET_PRIVATE_MODE=true
# Peer

EASYTIER_PROTOCOL=tcp
EASYTIER_PUBLIC_IP=
EASYTIER_PORT=11010

ET_PEERS=${EASYTIER_PROTOCOL:-tcp}://${EASYTIER_PUBLIC_IP}:${EASYTIER_PORT:-11010}
# Stun Server
ET_STUN_SERVERS=1.2.3.4:3478
ET_STUN_SERVERS_V6=::ffff:102:304:3478

# ET_STUN_SERVERS=stun.example.com:3478
# ET_STUN_SERVERS_V6=stun-v6.example.com:3478
# Point-To-Network
ET_PROXY_NETWORKS=10.24.24.0/24